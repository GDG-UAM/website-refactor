{
    "$schema": "https://turbo.build/schema.json",
    "globalPassThroughEnv": ["PORT", "BACKEND_PORT", "NODE_ENV", "INTERNAL_BACKEND_URL", "NEXT_PUBLIC_BACKEND_URL", "INTERNAL_API_SECRET"],
    "tasks": {
        "type-check": {
            "cache": true,
            "dependsOn": ["^type-check"]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "env": ["PORT", "BACKEND_PORT", "NEXT_PUBLIC_BACKEND_URL", "INTERNAL_BACKEND_URL", "INTERNAL_API_SECRET"]
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "dist/**"],
            "env": ["NEXT_PUBLIC_BACKEND_URL", "INTERNAL_BACKEND_URL", "INTERNAL_API_SECRET"]
        }
    }
}
