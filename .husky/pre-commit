#!/usr/bin/env bash
echo "🔍 Running Monorepo Health Checks..."

# 1. Check Types (Turbo will run tsc in parallel for both apps)
bun x turbo run type-check || {
  echo "❌ Type check failed. Fix TypeScript errors before committing."
  exit 1
}

# Run tests for permissions package
bun run test:permissions || {
  echo "❌ Permissions tests failed. Commit aborted."
  exit 1
}

# Run linting
bun x lint-staged || {
  echo "❌ Linting failed."
  exit 1
}

echo "✅ Ready to commit!"