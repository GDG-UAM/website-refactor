    "about": {
        "pageTitle": "About Us",
        "pageDescription": "Learn more about GDG on Campus UAM, our mission, vision, history, and the team behind the community. Join us in our journey to connect and empower students through technology.",
        "title": "About Us",
        "subtitle": "[google] Developer Group on Campus - [uni]",
        "subtitle_google": "Google",
        "subtitle_uni": "Autonomous University of Madrid",
        "intro": "We are a university community passionate about technology. Here we connect, learn, and grow together, exploring Google tools and solving real challenges. If you love technology, this is your place.",
        "missionTitle": "Our Mission",
        "whatWeDoTitle": "What We Do",
        "mission": {
            "_0": {
                "title": "Connect with the professional world",
                "text": "We bring the professional world closer to students with talks, workshops, and spaces to make contacts that boost your career."
            },
            "_1": {
                "title": "Make programming fun",
                "text": "We create an environment where learning to program is entertaining and collaborative, full of challenges and creativity."
            },
            "_2": {
                "title": "Stay up to date",
                "text": "We discover the latest trends in technology together and share that curiosity for what's new."
            },
            "_3": {
                "title": "Improve campus life",
                "text": "We apply our skills to make campus more connected, modern, and useful for everyone."
            }
        },
        "whatWeDo": {
            "_0": {
                "title": "Talks with Speakers (Google Developer Expert)",
                "description": "Listen to experts and professionals who share ideas and experiences from the tech world."
            },
            "_1": {
                "title": "Hackathons",
                "description": "Marathons where we create tech solutions as a team and put our creativity to the test."
            },
            "_2": {
                "title": "Events",
                "description": "Meetups to connect, share, and grow as a community."
            },
            "_3": {
                "title": "Workshops",
                "description": "Learn by doing: hands-on workshops on AI, Machine Learning, and more."
            }
        },
        "visionTitle": "Our Vision",
        "vision": "We want technology to be accessible to everyone at the university. We aim to be the place where ideas and projects are born that improve daily life.",
        "historyTitle": "Where do we come from? The history of GDG",
        "history": "Google Developer Groups (GDG) are communities of developers around the world interested in Google technologies. The initiative focuses on learning, connection, and professional growth. Each GDG group is a local meeting point where developers share knowledge, build successful products, and network.",
        "disclaimer": " is an independent group. Our activities and opinions expressed in this group should not be linked in any way to Google, the corporation.",
        "connectTitle": "Connect with us!",
        "connect": "If you are interested in technology and want to be part of an active community, join us! Follow us on social media and participate in our events to learn, grow, and build with us.",
        "teamTitle": "Our Team",
        "organizersTitle": "GDG Organizers",
        "membersTitle": "Team Members",
        "organizerRoleLabel": "GDG Organizer",
        "memberRoleLabel": "Team Member"
    },
