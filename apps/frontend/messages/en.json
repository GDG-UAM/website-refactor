        "faq": {
            "title": "Frequently asked questions",
            "items": {
                "_0": {
                    "q": "Do I need prior experience to attend?",
                    "a": "No. Our events are open to all levels unless otherwise stated in the description, and we encourage beginners to join in."
                },
                "_1": {
                    "q": "Can I give a talk?",
                    "a": "We'd love that! Send us your idea with a title, a short summary (3-5 lines), estimated duration, and any relevant links. We'll provide feedback and help you prepare."
                },
                "_2": {
                    "q": "What does sponsorship involve?",
                    "a": "It can be financial support or in-kind contributions (venues, food, swag, mentors…). In return, we offer brand visibility and access to talent. Tell us your goals and we'll suggest a good fit."
                },
                "_3": {
                    "q": "How can I become a volunteer?",
                    "a": "Reach out through the form on this page. We'll set up an interview to get to know you better and see how you might fit into the team."
                }
            }
        }
