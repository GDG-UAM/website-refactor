{
    "name": "frontend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3001",
        "build": "bun run paraglide:compile && next build",
        "start": "next start",
        "type-check": "tsc --noEmit",
        "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide"
    },
    "imports": {
        "#/*": "./src/*",
        "#app/*": "./app/*"
    },
    "dependencies": {
        "@elysiajs/eden": "latest",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@gdg-uam/permissions": "workspace:*",
        "@heroui/button": "^2.2.29",
        "@inlang/paraglide-js": "^2.7.1",
        "@inlang/paraglide-next": "^0.8.1",
        "@mui/material": "^7.3.6",
        "@sentry/nextjs": "^10.32.1",
        "@types/qrcode": "^1.5.6",
        "@types/sanitize-html": "^2.16.0",
        "backend": "workspace:*",
        "better-auth": "^1.4.10",
        "blurhash": "^2.0.5",
        "framer-motion": "^12.25.0",
        "highlight.js": "^11.11.1",
        "html-react-parser": "^5.2.11",
        "marked": "^17.0.1",
        "marked-highlight": "^2.2.3",
        "next": "16.1.1",
        "next-extra": "^0.7.0",
        "postcss": "^8.5.6",
        "qrcode": "^1.5.4",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "sanitize-html": "^2.17.0",
        "styled-components": "^6.1.19"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.18",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.1",
        "tailwindcss": "^4.1.18",
        "typescript": "^5",
        "typescript-eslint": "^8.51.0"
    }
