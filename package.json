{
    "name": "web-refactor",
    "private": true,
    "packageManager": "bun@1.3.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "lint-staged": {
        "apps/frontend/**/*.{ts,tsx}": [
            "bun x prettier --write"
        ],
        "apps/backend/**/*.{ts,tsx}": [
            "bun x prettier --write",
            "bun x eslint --fix --config apps/backend/eslint.config.mjs"
        ]
    },
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "build:permissions": "turbo run build:permissions",
        "test:permissions": "bun test --cwd packages/permissions --reporter dots",
        "prepare": "husky"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "husky": "^9.1.7",
        "turbo": "^2.8.2"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
