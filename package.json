{
    "name": "web-refactor",
    "private": true,
    "packageManager": "bun@1.3.0",
    "workspaces": [
        "apps/*"
    ],
    "lint-staged": {
        "apps/frontend/**/*.{ts,tsx}": [
            "bun x prettier --write"
        ],
        "apps/backend/**/*.{ts,tsx}": [
            "bun x prettier --write",
            "bun x eslint --fix --config apps/backend/eslint.config.mjs"
        ]
    },
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "prepare": "husky"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "husky": "^9.1.7",
        "turbo": "^2.7.2"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}